{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nogra.local/brief-v1.schema.json",
  "title": "Nogra Brief v1",
  "type": "object",
  "required": [
    "schema",
    "releaseVersion",
    "briefId",
    "workspaceId",
    "title",
    "createdAt",
    "intent",
    "contextHandoff",
    "scope",
    "successCriteria",
    "stopCriteria",
    "maxOutput"
  ],
  "properties": {
    "schema": {
      "const": "nogra.brief.v1"
    },
    "releaseVersion": {
      "type": "string",
      "pattern": "^v[1-9][0-9]*\\.[0-9]+\\.[0-9]+$"
    },
    "briefId": {
      "type": "string",
      "pattern": "^brief-[A-Za-z0-9_.-]+$"
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "approved",
        "in_progress",
        "returned",
        "accepted",
        "archived"
      ],
      "default": "draft"
    },
    "owner": {
      "type": "string"
    },
    "targetRole": {
      "type": "string"
    },
    "targetModel": {
      "type": "string",
      "default": "anthropic:sonnet",
      "description": "Wildcard provider:model label. V1 defaults to Anthropic Sonnet."
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "contextHandoff": {
      "type": "string",
      "minLength": 1
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knownGaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "object",
      "required": [
        "in",
        "out"
      ],
      "properties": {
        "in": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "successCriteria": {
      "type": "array",
      "description": "Brief-specific conditions derived from the user's intent and approved scope; not generic quality gates.",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stopCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "maxOutput": {
      "type": "object",
      "description": "Return policy for the executor's final response. This is not a limit on brief length.",
      "required": [
        "format",
        "limit"
      ],
      "properties": {
        "format": {
          "type": "string"
        },
        "limit": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "executionShape": {
      "type": "object",
      "description": "Optional Manager-authored execution/tool-shape guidance. Prefer evidence/tool need declarations; explicit toolFamilies is a backward-compatible override. Blank means conservative default execution.",
      "properties": {
        "toolFamilies": {
          "type": "array",
          "description": "Backward-compatible capability-family override resolved through the runtime toolbank. Prefer toolNeeds/evidence declarations so the adapter derives families mechanically.",
          "items": {
            "type": "string"
          }
        },
        "toolNeeds": {
          "type": "array",
          "description": "Freeform evidence/tool need declarations, such as source review, read-only inspection or screenshot evidence. The adapter may derive toolbank families from these declarations.",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "evidenceRequired": {
      "type": "string",
      "description": "Evidence strength requested for completion. This does not automatically require a separate verifier agent.",
      "enum": [
        "reported",
        "edited",
        "tested",
        "verified"
      ],
      "default": "reported"
    },
    "handoffRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redactions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Secret-pattern category labels detected in this record at write time."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
